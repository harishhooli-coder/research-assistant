# Copy to .env and fill in. All values are read by settings.py.
# Nothing here is required to RUN THE TESTS (tests mock the LLM/tools and use
# fakeredis + SQLite), but the bot/api/worker need real values at runtime.

# --- LLM / tools ---
# Provider: "nvidia" (NIM) or "anthropic". Auto-detects from NVIDIA_API_KEY if unset.
LLM_PROVIDER=nvidia
NVIDIA_API_KEY=nvapi-...
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Anthropic (optional if using NVIDIA NIM)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
TAVILY_API_KEY=tvly-...

# --- Telegram bot (Phase 1) ---
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# --- Redis (arq queue + pub/sub + episodic memory) ---
# Local docker-compose default:
REDIS_URL=redis://localhost:6379

# --- Database (Neon Postgres — async SQLAlchemy URL) ---
# Sync URL from Neon dashboard, then use postgresql+asyncpg:// and ?ssl=require
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?ssl=require
# Optional: local Postgres via docker-compose for offline dev without Neon:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/research

# --- CORS (FastAPI) ---
# "*" allows all (dev). In prod set to your Vercel origin, comma-separated:
# CORS_ALLOW_ORIGINS=https://your-app.vercel.app
CORS_ALLOW_ORIGINS=*

# --- Agent limits (optional overrides) ---
MAX_SUPERVISOR_STEPS=5
MAX_CONTEXT_TOKENS=8000
MAX_FETCH_CHARS=6000
