# Copy to .env.local for local dev, or set in Vercel (Production + Preview).
#
# Public URL of the FastAPI backend. The browser calls this directly (CORS must
# allow your Vercel origin on the API — see CORS_ALLOW_ORIGINS in the backend).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production example (Fly.io):
# NEXT_PUBLIC_API_URL=https://research-api.fly.dev

# Clerk (https://dashboard.clerk.com → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Playwright e2e (optional — defaults shown)
# E2E_CLERK_USER_EMAIL=e2e+clerk_test@example.com
# E2E_CLERK_USER_PASSWORD=E2eTestPass123!
